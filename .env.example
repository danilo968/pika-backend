# ============================================
# PIKA APP - Backend Environment Variables
# Copy to .env and fill in your values
# ============================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Database ---
# For local dev: localhost. For Docker: postgres (container name)
DATABASE_URL=postgresql://ku_user:ku_password@localhost:5432/ku_db

# --- JWT Authentication ---
# IMPORTANT: Generate secure secrets for production!
# Run: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_REFRESH_SECRET=your-refresh-secret-change-this
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- File Uploads ---
# Local dev: ./uploads | Docker: /app/uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# --- Email (SMTP) ---
# Required for account verification & password reset emails
# See SETUP-GUIDE.txt Section 8 for provider options
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=Pika <noreply@your-domain.com>

# --- Mapbox (Navigation / Directions) ---
# Get your token at: https://account.mapbox.com
# Free tier: 100,000 requests/month
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# --- Typesense (Search Engine) ---
# Self-hosted via Docker. Default dev key matches docker-compose.yml
# For Docker: host=typesense | For local dev: host=localhost
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=pika_typesense_dev_key

# --- Payment Gateway (optional, for premium subscriptions) ---
# See SETUP-GUIDE.txt Section 9 for provider options
# PAYMENT_API_KEY=your_payment_provider_key
# PAYMENT_WEBHOOK_SECRET=your_webhook_secret
